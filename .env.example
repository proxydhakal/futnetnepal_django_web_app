# =============================================================================
# Futnet Nepal — environment variables (copy to .env)
# Loaded via python-dotenv (see futnetnepal/env.py)
# =============================================================================
# Local development: DEBUG=True, USE_SQLITE=True
# Production server:  DEBUG=False, USE_SQLITE=False, MySQL below
# =============================================================================

# --- Required ---
SECRET_KEY=change-me-generate-a-long-random-string
DEBUG=True

# Hosts (comma-separated). Required when DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,futnetnepal.com,www.futnetnepal.com

# Public site URL (no trailing slash) — used in emails and absolute links
SITE_URL=http://127.0.0.1:8000

# --- Database ---
# Local: SQLite
USE_SQLITE=True

# Production: MySQL via PyMySQL (set USE_SQLITE=False)
USE_SQLITE=False
DB_ENGINE=django.db.backends.mysql
DB_NAME=futnetnepal
DB_USER=futnet_user
DB_PASSWORD=your-mysql-password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_CONN_MAX_AGE=60

# Optional legacy URL (sqlite:///… only for local)
# DATABASE_URL=sqlite:///db.sqlite3

# --- Static & media ---
STATIC_URL=/static/
STATIC_ROOT=staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=media

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=info@futnetnepal.com
EMAIL_HOST_PASSWORD=
# Must match EMAIL_HOST_USER (or an allowed alias on your mail server)
DEFAULT_FROM_EMAIL=info@futnetnepal.com
SERVER_EMAIL=info@futnetnepal.com
# Admin inbox for contact/newsletter notifications
FUTNET_INFO_EMAIL=info@futnetnepal.com
EMAIL_TIMEOUT=30
# Optional: redirect ALL outbound mail to one inbox while testing (leave empty in production)
# EMAIL_OVERRIDE_RECIPIENT=you@gmail.com

# --- JWT (mobile API) ---
JWT_ACCESS_MINUTES=1440
JWT_REFRESH_DAYS=30

# --- CORS (django-cors-headers; applies to /api/* only) ---
# Production: list every web origin that calls the API (comma-separated, no trailing slash)
CORS_ALLOWED_ORIGINS=https://futnetnepal.com,https://www.futnetnepal.com
# Optional regex origins, e.g. preview deployments: ^https://.*\.vercel\.app$
# CORS_ALLOWED_ORIGIN_REGEXES=
# Local DEBUG: allow any origin (default True). Set False to use localhost list only.
# CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOW_CREDENTIALS=False
CORS_PREFLIGHT_MAX_AGE=86400

# --- HTTPS / CSRF (production behind nginx or similar) ---
CSRF_TRUSTED_ORIGINS=https://futnetnepal.com,https://www.futnetnepal.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000

# --- Redis (required for multi-worker WebSockets / notifications) ---
REDIS_URL=redis://127.0.0.1:6379/0
# Or: REDIS_HOST=127.0.0.1 REDIS_PORT=6379 REDIS_PASSWORD=

# --- SMS (Aakash) ---
AAKASH_SMS_AUTH_TOKEN=

# --- OTP tuning ---
PHONE_OTP_EXPIRY_MINUTES=10
PHONE_OTP_RESEND_COOLDOWN_SECONDS=60
PHONE_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_EXPIRY_MINUTES=15
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_OTP_MAX_ATTEMPTS=5

# --- Misc ---
TIME_ZONE=Asia/Kathmandu

# --- Logging (console stream; each line includes rid= request correlation id) ---
LOG_LEVEL=INFO
# Trim long JSON/form bodies in request/response logs
LOG_BODY_MAX_CHARS=2048
LOG_REQUEST_BODY=True
LOG_RESPONSE_BODY=True
# Set True to log every SQL query (verbose)
LOG_SQL=False
